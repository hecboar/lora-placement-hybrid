# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Experiment artifacts (too large / reproducible) ──────────
checkpoints/
data_cache/
models/
analysis_cache/
module_trees/
logs/
*.pkl
*.safetensors
*.bin

# ── Claude Code ───────────────────────────────────────────────
.claude/

# ── Staging archives (not part of the release) ────────────────
*.zip

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── LaTeX source ──────────────────────────────────────────────
*.tex
